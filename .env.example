# Copy to .env and fill only what you use. Never commit real secrets.

# ClickUp
CLICKUP_API_TOKEN=
CLICKUP_WORKSPACE_ID=
CLICKUP_CHANNEL_ID=
# Optional: exact ClickUp Channel message endpoint if your workspace exposes one.
# When set, the agent posts the report body here before trying inferred channel routes.
CLICKUP_CHANNEL_POST_URL=
# Fallback task destination. Required if Channel posting fails.
CLICKUP_FALLBACK_LIST_ID=

# Reddit OAuth (recommended). Anonymous Reddit endpoints get 429-blocked from
# shared/cloud IPs. Create a "script" app at https://www.reddit.com/prefs/apps
# (type: script) and fill all four. When set, the agent uses authenticated
# oauth.reddit.com (~100 req/min) and only falls back to public routes on error.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Optional connector tuning
# Make the user agent unique to you (Reddit asks for "platform:appid:version by /u/you").
REDDIT_USER_AGENT=morning-brief/0.1 by StudioLowFive
REDDIT_USE_JSON=false
REDDIT_DELAY_MS=1200
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=

# Job listings via JSearch (RapidAPI, free tier). Subscribe at
# rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch and paste your key. Powers the
# Roles & Gigs (Track B) section. Leave blank to disable job pulls.
JSEARCH_API_KEY=
JOBS_DATE_POSTED=week
MAX_ITEMS_PER_SOURCE=15
CONNECTOR_DELAY_MS=0

# Signal store: drop collected signals older than this many days on each run.
SIGNAL_RETENTION_DAYS=14

# Quality gate: only signals scoring >= this (1-5) appear in the brief. The brief
# does NOT pad to a fixed count — a thin day shows few or zero signals on purpose.
QUALITY_BAR=3

# Local LLM (Ollama). Used only while a brief is generated; the model is
# unloaded from VRAM right after, so the GPU is idle between runs. The brief
# falls back to keyword scoring if Ollama or the model is unavailable.
LLM_ENABLED=true
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_KEEP_ALIVE=5m
LLM_CLASSIFY_BATCH=12

# Polish tier (optional): after Qwen filters/ranks, the Claude Code CLI writes
# the final prose under your Claude subscription (no API billing). Requires a
# one-time `claude` login on this machine; falls back to Qwen if unavailable.
LLM_POLISH_PROVIDER=
CLAUDE_CLI_PATH=
CLAUDE_CLI_MODEL=

# Feedback loop: posts each signal as a reactable ClickUp message, reads your
# emoji reactions (🔥 more / 👍 useful / 👎 noise / ✅ acted on), and tunes future
# ranking. Set FEEDBACK_ENABLED=false to post a single whole-report message instead.
FEEDBACK_ENABLED=true
FEEDBACK_WINDOW_DAYS=14
FEEDBACK_STRENGTH=1
# Don't resurface a signal shown within this many days (🔁 suppresses for good).
REPEAT_WINDOW_DAYS=30

# Auto-start the Ollama daemon if it isn't running when a brief is built.
OLLAMA_AUTOSTART=true

# Report/runtime
MORNING_BRIEF_TIMEZONE=America/Chicago
MORNING_BRIEF_DRY_RUN=false
